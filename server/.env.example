CLIENT_URL=http://localhost:5173
CLOUDINARY_CLOUD_NAME=optional
CLOUDINARY_API_KEY=optional
CLOUDINARY_API_SECRET=optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=example@example.com
